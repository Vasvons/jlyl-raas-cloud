{
  "platform": "dy",
  "version": "1.7.3",
  "description": "抖音图文发布流程（v1.7.3：精确图片上传选择器，排除视频 input）",
  "is_placeholder": false,
  "login_check_url": "https://creator.douyin.com/creator-micro/content/upload?default-tab=3",
  "login_check_selector": ".user-info | .avatar",
  "login_check_url_pattern": "^https://creator\\.douyin\\.com/.*login.*",
  "logout_keywords": ["登录", "请登录", "sign in"],
  "steps": [
    {
      "type": "navigate",
      "value": "https://creator.douyin.com/creator-micro/content/upload?default-tab=3",
      "descript": "导航到抖音图文上传页",
      "timeout": 30000
    },
    {
      "type": "wait_for_url",
      "value": "content/upload",
      "descript": "等待进入上传页",
      "timeout": 15000
    },
    {
      "type": "timing",
      "ms": 2500,
      "descript": "等待上传组件加载完成"
    },
    {
      "type": "input_files",
      "selector": "//input[@type='file' and (@accept='image/*' or contains(@accept,'image'))] | //input[@type='file' and contains(@class,'image')] | //div[contains(@class,'image-upload')]//input[@type='file'] | //input[@type='file' and not(contains(@accept,'video'))]",
      "files": ["{cover_image_url}"],
      "descript": "上传图片（封面图）- 精确匹配图片 input，排除视频 input",
      "ai_fallback": true,
      "ai_intent": "找到抖音图文上传图片的文件选择按钮（注意不要选到视频上传 input）",
      "timeout": 15000
    },
    {
      "type": "timing",
      "ms": 5000,
      "descript": "等待图片上传完成（抖音 OSS 上传 + 服务端处理）"
    },
    {
      "type": "fill",
      "selector": "//input[@placeholder='添加作品标题'] | //input[contains(@placeholder,'标题')] | //input[contains(@class,'title')]",
      "value": "{title}",
      "descript": "填写标题",
      "ai_fallback": true,
      "ai_intent": "找到抖音标题输入框并填写",
      "timeout": 8000
    },
    {
      "type": "timing",
      "ms": 800,
      "descript": "等待标题渲染完成"
    },
    {
      "type": "press",
      "selector": "//div[@contenteditable='true'][contains(@class,'ql-editor')] | //div[@contenteditable='true'][contains(@data-role,'editor')] | //div[@contenteditable='true'][contains(@class,'editor')] | //div[@contenteditable='true']",
      "value": "{content}",
      "descript": "在「添加作品描述」编辑器中填入正文（contenteditable 富文本，press 长字符串自动转 execContent 剪贴板粘贴）",
      "ai_fallback": true,
      "ai_intent": "找到抖音「添加作品描述」富文本编辑区并填入正文内容",
      "timeout": 10000
    },
    {
      "type": "timing",
      "ms": 800,
      "descript": "等待正文渲染完成"
    },
    {
      "type": "tags",
      "selector": "//input[@placeholder='添加话题'] | //input[contains(@class,'tag')]//input | //div[contains(@class,'tag')]//input | //input[contains(@placeholder,'话题')]",
      "value": "{tags}",
      "descript": "添加话题（每个话题回车确认）",
      "is_try": true,
      "timeout": 8000
    },
    {
      "type": "timing",
      "ms": 800,
      "descript": "等待话题渲染完成"
    },
    {
      "type": "branch",
      "condition": "data_item.poi_name",
      "branch_steps": [
        {
          "type": "click",
          "selector": "div.semi-select span:has-text(\"输入相关位置\")",
          "descript": "点击位置选择",
          "is_try": true,
          "timeout": 5000
        }
      ],
      "descript": "位置选择分支"
    },
    {
      "type": "branch",
      "condition": "data_item.shop_url",
      "branch_steps": [
        {
          "type": "fill",
          "selector": "//input[@placeholder=\"粘贴商品链接\"]",
          "value": "data_item.shop_url",
          "descript": "填写商品链接",
          "is_try": true,
          "timeout": 5000
        },
        {
          "type": "click",
          "selector": "//span[text()=\"添加链接\"]",
          "descript": "点击添加链接",
          "is_try": true,
          "timeout": 5000
        }
      ],
      "descript": "商品链接分支"
    },
    {
      "type": "timing",
      "ms": 1000,
      "descript": "等待表单稳定"
    },
    {
      "type": "click",
      "selector": "//button[.//span[text()=\"发布\"]] | //button[text()=\"发布\"] | //span[text()=\"直接发布\"] | //button[contains(@class,'btn-primary')]//span[text()=\"发布\"] | //div[contains(@class,'publish')]//button",
      "descript": "点击发布按钮",
      "ai_fallback": true,
      "ai_intent": "找到抖音发布按钮并点击（注意不要误点保存草稿按钮）",
      "timeout": 8000,
      "force": true
    },
    {
      "type": "wait_for_url",
      "value": "content/manage",
      "descript": "等待发布成功跳转到内容管理页",
      "timeout": 45000
    },
    {
      "type": "evaluate_edit",
      "value": "return window.location.href;",
      "descript": "获取发布后 URL",
      "timeout": 3000
    }
  ]
}
