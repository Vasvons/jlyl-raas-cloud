{
  "platform": "dy",
  "version": "1.0.0",
  "description": "抖音图文发布流程：creator.douyin.com（v1.5.6 模板，抖音以视频为主，图文发布需上传图片+文案）",
  "is_placeholder": true,
  "login_check_url": "https://creator.douyin.com/creator-micro/home",
  "login_check_selector": "//div[contains(@class,'user-info')] | //div[contains(@class,'avatar')]",
  "logout_keywords": ["登录", "请登录", "sign in"],
  "steps": [
    {
      "type": "navigate",
      "value": "https://creator.douyin.com/creator-micro/content/upload",
      "descript": "导航到抖音创作者中心发布页",
      "timeout": 30000
    },
    {
      "type": "wait_for_selector",
      "selector": "//div[contains(@class,'upload')] | //input[@type='file'] | //div[contains(@class,'tab')][contains(text(),'图文')]",
      "descript": "等待发布页加载（需切换到图文 tab）",
      "timeout": 15000
    },
    {
      "type": "click",
      "selector": "//div[contains(@class,'tab')][contains(text(),'图文')] | //span[contains(text(),'图文')]/..",
      "descript": "切换到图文发布模式（抖音默认视频）",
      "timeout": 5000,
      "is_try": true
    },
    {
      "type": "fill",
      "selector": "//input[@placeholder='填写标题'] | //input[contains(@class,'title')] | //div[contains(@class,'title-input')]//input",
      "value": "{title}",
      "descript": "填写标题",
      "timeout": 5000,
      "is_try": true
    },
    {
      "type": "click",
      "selector": "//div[@contenteditable='true'] | //div[contains(@class,'desc-input')] | //div[contains(@class,'content-input')]",
      "descript": "点击正文编辑区",
      "timeout": 5000,
      "is_try": true
    },
    {
      "type": "content",
      "selector": "//div[@contenteditable='true'] | //div[contains(@class,'desc-input')] | //div[contains(@class,'content-input')]",
      "value": "{content}",
      "descript": "粘贴正文",
      "timeout": 10000,
      "is_try": true
    },
    {
      "type": "click",
      "selector": "//button[contains(text(),'发布')] | //button[contains(@class,'publish-btn')]",
      "descript": "点击发布按钮",
      "timeout": 8000
    },
    {
      "type": "evaluate_edit",
      "value": "return window.location.href;",
      "descript": "获取发布后 URL",
      "timeout": 3000
    }
  ]
}
