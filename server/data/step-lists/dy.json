{
  "platform": "dy",
  "version": "1.7.0",
  "description": "抖音图文发布流程（基于 tiktok.pyc 反编译的真实确定性步骤 + AI 兜底）",
  "is_placeholder": false,
  "login_check_url": "https://creator.douyin.com/creator-micro/content/upload?default-tab=3",
  "login_check_selector": ".user-info | .avatar",
  "login_check_url_pattern": "^https://creator\\.douyin\\.com/.*login.*",
  "logout_keywords": ["登录", "请登录", "sign in"],
  "steps": [
    {
      "type": "navigate",
      "value": "https://creator.douyin.com/creator-micro/content/upload?default-tab=3",
      "descript": "导航到抖音图文上传页",
      "timeout": 30000
    },
    {
      "type": "wait_for_url",
      "value": "content/upload",
      "descript": "等待进入上传页",
      "timeout": 15000
    },
    {
      "type": "input_files",
      "selector": "//input[@type='file']",
      "files": ["{cover_image_url}"],
      "descript": "上传图片",
      "ai_fallback": true,
      "ai_intent": "找到文件上传按钮并上传",
      "timeout": 10000
    },
    {
      "type": "fill",
      "selector": "//input[@placeholder='添加作品标题']",
      "value": "{title}",
      "descript": "填写标题",
      "ai_fallback": true,
      "ai_intent": "找到抖音标题输入框并填写",
      "timeout": 5000
    },
    {
      "type": "tags",
      "selector": "//input[@placeholder='添加话题'] | //div[contains(@class,'tag')]//input",
      "value": "{tags}",
      "descript": "添加话题",
      "is_try": true,
      "timeout": 5000
    },
    {
      "type": "branch",
      "condition": "data_item.poi_name",
      "branch_steps": [
        {
          "type": "click",
          "selector": "div.semi-select span:has-text(\"输入相关位置\")",
          "descript": "点击位置选择",
          "is_try": true,
          "timeout": 5000
        }
      ],
      "descript": "位置选择分支"
    },
    {
      "type": "branch",
      "condition": "data_item.shop_url",
      "branch_steps": [
        {
          "type": "fill",
          "selector": "//input[@placeholder=\"粘贴商品链接\"]",
          "value": "data_item.shop_url",
          "descript": "填写商品链接",
          "is_try": true,
          "timeout": 5000
        },
        {
          "type": "click",
          "selector": "//span[text()=\"添加链接\"]",
          "descript": "点击添加链接",
          "is_try": true,
          "timeout": 5000
        }
      ],
      "descript": "商品链接分支"
    },
    {
      "type": "click",
      "selector": "//button[text()=\"发布\"] | //span[text()=\"直接发布\"]",
      "descript": "点击发布",
      "ai_fallback": true,
      "ai_intent": "找到抖音发布按钮并点击",
      "timeout": 5000
    },
    {
      "type": "wait_for_url",
      "value": "content/manage",
      "descript": "等待发布成功跳转",
      "timeout": 30000
    },
    {
      "type": "evaluate_edit",
      "value": "return window.location.href;",
      "descript": "获取发布后 URL",
      "timeout": 3000
    }
  ]
}
