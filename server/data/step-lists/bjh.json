{
  "platform": "bjh",
  "version": "1.0.0",
  "description": "百家号图文发布流程：baijiahao.baidu.com/builder/rc/edit（v1.5.6 模板，需基于实测调整选择器）",
  "is_placeholder": true,
  "login_check_url": "https://baijiahao.baidu.com/builder/rc/home",
  "login_check_selector": "//div[contains(@class,'avatar')] | //img[contains(@class,'portrait')]",
  "logout_keywords": ["登录", "请登录", "sign in"],
  "steps": [
    {
      "type": "navigate",
      "value": "https://baijiahao.baidu.com/builder/rc/edit",
      "descript": "导航到百家号图文编辑页",
      "timeout": 30000
    },
    {
      "type": "wait_for_selector",
      "selector": "//input[@placeholder='请输入文章标题'] | //input[contains(@class,'title-input')] | //textarea[contains(@class,'title')]",
      "descript": "等待标题输入框",
      "timeout": 15000
    },
    {
      "type": "fill",
      "selector": "//input[@placeholder='请输入文章标题'] | //input[contains(@class,'title-input')] | //textarea[contains(@class,'title')]",
      "value": "{title}",
      "descript": "填写标题",
      "timeout": 5000
    },
    {
      "type": "click",
      "selector": "//div[@contenteditable='true'] | //div[contains(@class,'editor-content')] | //div[contains(@class,'ql-editor')]",
      "descript": "点击正文编辑区",
      "timeout": 5000
    },
    {
      "type": "content",
      "selector": "//div[@contenteditable='true'] | //div[contains(@class,'editor-content')] | //div[contains(@class,'ql-editor')]",
      "value": "{content}",
      "descript": "粘贴正文",
      "timeout": 10000
    },
    {
      "type": "click",
      "selector": "//button[contains(text(),'发布')] | //button[contains(@class,'publish-btn')] | //span[contains(text(),'发布')]/..",
      "descript": "点击发布按钮",
      "timeout": 8000
    },
    {
      "type": "wait_for_selector",
      "selector": "//div[contains(@class,'dialog')] | //button[contains(text(),'确认')] | //button[contains(text(),'确定')]",
      "descript": "等待确认弹窗（若有）",
      "timeout": 5000,
      "is_try": true
    },
    {
      "type": "click",
      "selector": "//button[contains(text(),'确认发布')] | //button[contains(text(),'确定')] | //button[contains(text(),'确认')]",
      "descript": "确认发布（如有弹窗）",
      "timeout": 5000,
      "is_try": true
    },
    {
      "type": "wait_for_url",
      "value": "baijiahao.baidu.com/builder/rc/content",
      "descript": "等待跳转到内容管理页",
      "timeout": 30000
    },
    {
      "type": "evaluate_edit",
      "value": "return window.location.href;",
      "descript": "获取发布后 URL",
      "timeout": 3000
    }
  ]
}
