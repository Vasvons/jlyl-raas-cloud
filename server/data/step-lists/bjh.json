{
  "platform": "bjh",
  "version": "1.7.3",
  "description": "百家号图文发布流程（基于 baidu.pyc 反编译的真实确定性步骤 + AI 兜底）",
  "is_placeholder": false,
  "login_check_url": "https://baijiahao.baidu.com/builder/rc/home",
  "login_check_selector": "//div[contains(@class,'avatar')] | //img[contains(@class,'portrait')]",
  "login_check_url_pattern": "^https://baijiahao\\.baidu\\.com/builder/theme/bjh/login",
  "logout_keywords": ["请登录", "sign in"],
  "steps": [
    {
      "type": "navigate",
      "value": "https://baijiahao.baidu.com/builder/rc/edit?type=news&is_from_cms=1",
      "descript": "导航到百家号新建图文编辑页",
      "timeout": 30000
    },
    {
      "type": "click",
      "selector": "//span[text()=\"我知道了\"] | //button[@class=\"cheetah-tour-close\"] | div.c27d9e2f3e73a2ac-btn-close | //span[text()=\"好的\"]",
      "descript": "关闭我知道了弹窗",
      "is_try": true,
      "timeout": 5000
    },
    {
      "type": "fill",
      "selector": "//div[@class=\"FeEditorApp-_9ddb7e475b559749-editor FeEditorApp-_377c94a778c072b3-editor\"] | //textarea[@placeholder=\"请输入标题\"]",
      "value": "{title}",
      "descript": "填写文章标题",
      "ai_fallback": true,
      "ai_intent": "找到文章标题输入框并填写标题",
      "timeout": 5000
    },
    {
      "type": "iframe_selector",
      "iframe": "iframe[id^=\"ueditor\"]",
      "descript": "进入 ueditor 正文 iframe",
      "is_list": [
        {
          "type": "press",
          "selector": "body[contenteditable=\"true\"]",
          "value": "{content}",
          "descript": "输入正文",
          "ai_fallback": true,
          "ai_intent": "在 ueditor 编辑器中输入正文",
          "timeout": 5000
        }
      ]
    },
    {
      "type": "click",
      "selector": "//span[text()=\"单图\"]",
      "descript": "选择单图封面",
      "is_try": true,
      "timeout": 5000
    },
    {
      "type": "click",
      "selector": "div.DraggableTags-tag-drag div.coverUploaderView",
      "descript": "点击上传图片焦点",
      "is_try": true,
      "timeout": 5000
    },
    {
      "type": "click",
      "selector": "//button//span[text()=\"确定 (1)\"]",
      "descript": "确认图片",
      "is_try": true,
      "timeout": 5000
    },
    {
      "type": "branch",
      "condition": "data_item.ai_status === true",
      "branch_steps": [
        {
          "type": "click",
          "selector": "//span[text()=\"采用AI生成内容\"]",
          "descript": "勾选AI创作声明",
          "is_try": true,
          "timeout": 5000
        }
      ],
      "descript": "AI创作声明分支"
    },
    {
      "type": "branch",
      "condition": "data_item.guazai_phone === true",
      "branch_steps": [
        {
          "type": "click",
          "selector": "//span[text()=\"挂载营销通电话\"]",
          "descript": "勾选挂载营销通电话",
          "is_try": true,
          "timeout": 5000
        }
      ],
      "descript": "挂载营销通电话分支"
    },
    {
      "type": "timing",
      "ms": 1000,
      "descript": "等待选项生效"
    },
    {
      "type": "click",
      "selector": "//button//span[text()=\"发布\"] | //div[text()=\"发布\"]/parent::div",
      "descript": "点击发布按钮",
      "force": true,
      "timeout": 5000
    },
    {
      "type": "timing",
      "ms": 1000,
      "descript": "等待 popconfirm 气泡确认框出现"
    },
    {
      "type": "click",
      "selector": "//div[contains(@class,'cheetah-popconfirm')]//button[contains(@class,'primary')]//span | //div[contains(@class,'popconfirm')]//button[contains(@class,'primary')]//span | //div[contains(@class,'pop-buttons')]//span[text()=\"确认\"] | //button[contains(text(),\"确认\")]",
      "descript": "点击 popconfirm 确认按钮（百家号发布需二次确认）",
      "is_try": true,
      "timeout": 5000
    },
    {
      "type": "wait_for_selector",
      "selector": "//p[text()=\"提交成功，正在审核中...\"] | //p[contains(text(),\"提交成功\")] | //p[contains(text(),\"发布成功\")] | //div[contains(text(),\"审核中\")] | //div[contains(@class,\"success\")]",
      "descript": "等待发布成功",
      "is_try": true,
      "timeout": 60000
    },
    {
      "type": "evaluate_edit",
      "value": "return window.location.href;",
      "descript": "获取发布后 URL",
      "timeout": 3000
    }
  ]
}
