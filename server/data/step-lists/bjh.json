{
  "platform": "bjh",
  "version": "1.7.4",
  "description": "百家号图文发布流程（基于 baidu.pyc 反编译的真实确定性步骤 + AI 兜底）",
  "is_placeholder": false,
  "login_check_url": "https://baijiahao.baidu.com/builder/rc/home",
  "login_check_selector": "//div[contains(@class,'avatar')] | //img[contains(@class,'portrait')]",
  "login_check_url_pattern": "^https://baijiahao\\.baidu\\.com/builder/theme/bjh/login",
  "logout_keywords": ["请登录", "sign in"],
  "steps": [
    {
      "type": "navigate",
      "value": "https://baijiahao.baidu.com/builder/rc/edit?type=news&is_from_cms=1",
      "descript": "导航到百家号新建图文编辑页",
      "timeout": 30000
    },
    {
      "type": "click",
      "selector": "//span[text()=\"我知道了\"] | //button[@class=\"cheetah-tour-close\"] | div.c27d9e2f3e73a2ac-btn-close | //span[text()=\"好的\"]",
      "descript": "关闭我知道了弹窗",
      "is_try": true,
      "timeout": 5000
    },
    {
      "type": "fill",
      "selector": "//div[@class=\"FeEditorApp-_9ddb7e475b559749-editor FeEditorApp-_377c94a778c072b3-editor\"] | //textarea[@placeholder=\"请输入标题\"]",
      "value": "{title}",
      "descript": "填写文章标题",
      "ai_fallback": true,
      "ai_intent": "找到文章标题输入框并填写标题",
      "timeout": 5000
    },
    {
      "type": "iframe_selector",
      "iframe": "iframe[id^=\"ueditor\"]",
      "descript": "进入 ueditor 正文 iframe",
      "is_list": [
        {
          "type": "press",
          "selector": "body[contenteditable=\"true\"]",
          "value": "{content}",
          "descript": "输入正文",
          "ai_fallback": true,
          "ai_intent": "在 ueditor 编辑器中输入正文",
          "timeout": 5000
        }
      ]
    },
    {
      "type": "click",
      "selector": "//span[text()=\"单图\"]",
      "descript": "选择单图封面",
      "is_try": true,
      "timeout": 5000
    },
    {
      "type": "input_files",
      "selector": "//div[contains(@class,'coverUploader')]//input[@type='file'] | //div[contains(@class,'cover')]//input[@type='file']",
      "files": ["{cover_image_url}"],
      "descript": "上传封面图片",
      "timeout": 30000
    },
    {
      "type": "timing",
      "ms": 3000,
      "descript": "等待封面上传完成"
    },
    {
      "type": "click",
      "selector": "//button//span[text()=\"确定 (1)\"] | //button//span[text()=\"确定\"]",
      "descript": "确认封面图片",
      "is_try": true,
      "timeout": 5000
    },
    {
      "type": "branch",
      "condition": "data_item.ai_status === true",
      "branch_steps": [
        {
          "type": "click",
          "selector": "//span[text()=\"采用AI生成内容\"]",
          "descript": "勾选AI创作声明",
          "is_try": true,
          "timeout": 5000
        }
      ],
      "descript": "AI创作声明分支"
    },
    {
      "type": "branch",
      "condition": "data_item.guazai_phone === true",
      "branch_steps": [
        {
          "type": "click",
          "selector": "//span[text()=\"挂载营销通电话\"]",
          "descript": "勾选挂载营销通电话",
          "is_try": true,
          "timeout": 5000
        }
      ],
      "descript": "挂载营销通电话分支"
    },
    {
      "type": "timing",
      "ms": 1000,
      "descript": "等待选项生效"
    },
    {
      "type": "click",
      "selector": "//button//span[text()=\"发布\"] | //div[text()=\"发布\"]/parent::div",
      "descript": "点击发布按钮",
      "force": true,
      "timeout": 5000
    },
    {
      "type": "timing",
      "ms": 1000,
      "descript": "等待 popconfirm 气泡确认框出现"
    },
    {
      "type": "click",
      "selector": "//div[contains(@class,'cheetah-popconfirm')]//button[contains(@class,'primary')]//span | //div[contains(@class,'popconfirm')]//button[contains(@class,'primary')]//span | //div[contains(@class,'pop-buttons')]//span[text()=\"确认\"] | //button[contains(text(),\"确认\")]",
      "descript": "点击 popconfirm 确认按钮（百家号发布需二次确认）",
      "is_try": true,
      "timeout": 5000
    },
    {
      "type": "timing",
      "ms": 3000,
      "descript": "等待发布请求完成"
    },
    {
      "type": "evaluate_edit",
      "value": "var bodyText = document.body.innerText; var hasError = bodyText.indexOf('请添加封面') >= 0 || bodyText.indexOf('封面不能为空') >= 0 || bodyText.indexOf('请上传封面') >= 0 || bodyText.indexOf('发布失败') >= 0 || bodyText.indexOf('不能为空') >= 0 || bodyText.indexOf('请填写') >= 0; if (hasError) { var errorTips = ['请添加封面','封面不能为空','请上传封面','发布失败','不能为空','请填写'].filter(function(s) { return bodyText.indexOf(s) >= 0; }); throw new Error('百家号发布失败: ' + errorTips.join(',')); } var hasSuccess = bodyText.indexOf('提交成功') >= 0 || bodyText.indexOf('发布成功') >= 0 || bodyText.indexOf('审核中') >= 0; var url = window.location.href; var urlChanged = url.indexOf('edit?type=news') < 0; if (!hasSuccess && !urlChanged) { throw new Error('百家号发布未成功: 未检测到成功提示且URL未跳转, url=' + url); } return JSON.stringify({ success: true, url: url, hasSuccess: hasSuccess });",
      "descript": "验证发布成功（检测错误提示如'请添加封面'，或成功提示/URL跳转）",
      "timeout": 5000
    }
  ]
}
