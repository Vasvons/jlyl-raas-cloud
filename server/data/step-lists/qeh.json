{
  "platform": "qeh",
  "version": "1.7.0",
  "description": "企鹅号图文发布流程（基于 qeh.pyc 反编译的真实确定性步骤 + AI 兜底）",
  "is_placeholder": false,
  "login_check_url": "https://om.qq.com/main/creation/article",
  "login_check_selector": ".user-info | .user-avatar",
  "login_check_url_pattern": "^https://om\\.qq\\.com/userAuth/index",
  "logout_keywords": ["登录", "请登录", "sign in"],
  "steps": [
    {
      "type": "navigate",
      "value": "https://om.qq.com/main/creation/article",
      "descript": "导航到企鹅号图文发布页",
      "timeout": 30000
    },
    {
      "type": "wait_for_url",
      "value": "creation/article",
      "descript": "等待进入发布页",
      "timeout": 15000
    },
    {
      "type": "fill",
      "selector": "//input[@placeholder=\"请输入标题\"] | //textarea[@placeholder=\"请输入标题\"]",
      "value": "{title}",
      "descript": "填写文章标题",
      "ai_fallback": true,
      "ai_intent": "找到企鹅号标题输入框并填写",
      "timeout": 5000
    },
    {
      "type": "press",
      "selector": "//div[@contenteditable=\"true\"]",
      "value": "{content}",
      "descript": "输入正文",
      "ai_fallback": true,
      "ai_intent": "找到企鹅号正文编辑区并填写内容",
      "timeout": 5000
    },
    {
      "type": "branch",
      "condition": "data_item.ai_status === true",
      "branch_steps": [],
      "descript": "AI声明分支（留空，未来扩展）"
    },
    {
      "type": "timing",
      "ms": 1000,
      "descript": "等待表单稳定"
    },
    {
      "type": "click",
      "selector": "//button[text()=\"提交\"] | //span[text()=\"提交\"]",
      "descript": "点击提交",
      "ai_fallback": true,
      "ai_intent": "找到企鹅号提交按钮并点击",
      "timeout": 5000
    },
    {
      "type": "click",
      "selector": "//button[text()=\"发布\"] | //span[text()=\"发布\"]",
      "descript": "点击发布",
      "ai_fallback": true,
      "ai_intent": "找到企鹅号发布按钮并点击",
      "timeout": 5000
    },
    {
      "type": "wait_for_url",
      "value": "articleManage",
      "descript": "等待发布成功跳转",
      "timeout": 30000
    },
    {
      "type": "evaluate_edit",
      "value": "return window.location.href;",
      "descript": "获取发布后 URL",
      "timeout": 3000
    }
  ]
}
