{
  "platform": "qeh",
  "version": "1.7.4",
  "description": "企鹅号图文发布流程（v1.7.4：基于实地登录验证——编辑页会加载草稿，标题/正文需用 clear_first 清空已有内容；标题选择器 span.omui-inputautogrowing__inner，正文选择器 .ProseMirror.ExEditor-basic）",
  "is_placeholder": false,
  "login_check_url": "https://om.qq.com/main/creation/article",
  "login_check_selector": "span.omui-inputautogrowing__inner[contenteditable=\"true\"] | .ProseMirror.ExEditor-basic",
  "login_check_url_pattern": "^https://om\\.qq\\.com/userAuth/index",
  "logout_keywords": ["请登录", "sign in"],
  "steps": [
    {
      "type": "navigate",
      "value": "https://om.qq.com/main/creation/article",
      "descript": "导航到企鹅号文章编辑页（会加载上次草稿，后续步骤会清空）",
      "timeout": 30000
    },
    {
      "type": "wait_for_selector",
      "selector": "span.omui-inputautogrowing__inner[contenteditable=\"true\"] | .ProseMirror.ExEditor-basic",
      "descript": "等待编辑器加载（标题或正文任一出现即可）",
      "timeout": 15000
    },
    {
      "type": "timing",
      "ms": 2000,
      "descript": "等待草稿加载完成"
    },
    {
      "type": "fill",
      "selector": "span.omui-inputautogrowing__inner[contenteditable=\"true\"]",
      "value": "{title}",
      "descript": "填写标题（fill 会自动替换已有内容）",
      "timeout": 5000
    },
    {
      "type": "content",
      "selector": ".ProseMirror.ExEditor-basic",
      "value": "{content}",
      "clear_first": true,
      "descript": "粘贴正文（先 Ctrl+A+Delete 清空草稿，再剪贴板粘贴 HTML）",
      "timeout": 15000
    },
    {
      "type": "timing",
      "ms": 1000,
      "descript": "等待表单稳定"
    },
    {
      "type": "click",
      "selector": "//button[contains(@class,'omui-button--primary') and text()='发布'] | //button[contains(@class,'omui-button--primary') and not(contains(text(),'定时')) and not(contains(text(),'草稿'))]",
      "descript": "点击发布按钮（排除定时发布按钮）",
      "timeout": 8000,
      "force": true
    },
    {
      "type": "wait_for_url",
      "value": "articleManage",
      "descript": "等待发布成功跳转到文章管理页",
      "timeout": 30000
    },
    {
      "type": "evaluate_edit",
      "value": "return window.location.href;",
      "descript": "获取发布后 URL",
      "timeout": 3000
    }
  ]
}
