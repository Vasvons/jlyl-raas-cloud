{
  "platform": "wxgzh",
  "version": "1.0.0",
  "description": "微信公众号图文发布流程：mp.weixin.qq.com（v1.5.6 模板，需基于实测调整选择器）",
  "is_placeholder": true,
  "login_check_url": "https://mp.weixin.qq.com/cgi-bin/home?t=home/index&lang=zh_CN",
  "login_check_selector": "//div[contains(@class,'account_box')] | //a[contains(@class,'weui-desktop-btn')]",
  "logout_keywords": ["登录", "请登录", "扫码登录"],
  "steps": [
    {
      "type": "navigate",
      "value": "https://mp.weixin.qq.com/cgi-bin/appmsg?t=media/appmsg_edit&action=edit&type=10&appmsgid=0&token=&lang=zh_CN",
      "descript": "导航到微信公众号图文编辑页（新建图文）",
      "timeout": 30000
    },
    {
      "type": "wait_for_selector",
      "selector": "//input[@id='title'] | //input[contains(@class,'title-input')] | //textarea[contains(@class,'title')]",
      "descript": "等待标题输入框",
      "timeout": 15000
    },
    {
      "type": "fill",
      "selector": "//input[@id='title'] | //input[contains(@class,'title-input')]",
      "value": "{title}",
      "descript": "填写标题",
      "timeout": 5000
    },
    {
      "type": "click",
      "selector": "//div[@id='ueditor_0'] | //div[@contenteditable='true'] | //body[contains(@class,'editor')]",
      "descript": "点击正文编辑区（UEditor）",
      "timeout": 5000
    },
    {
      "type": "content",
      "selector": "//div[@id='ueditor_0'] | //div[@contenteditable='true'] | //body[contains(@class,'editor')]",
      "value": "{content}",
      "descript": "粘贴正文",
      "timeout": 10000
    },
    {
      "type": "click",
      "selector": "//button[contains(text(),'群发')] | //a[contains(text(),'群发')] | //button[contains(text(),'发表')]",
      "descript": "点击群发/发表按钮",
      "timeout": 8000
    },
    {
      "type": "wait_for_selector",
      "selector": "//button[contains(text(),'确定')] | //div[contains(@class,'weui-desktop-dialog')]",
      "descript": "等待群发确认弹窗",
      "timeout": 5000,
      "is_try": true
    },
    {
      "type": "click",
      "selector": "//button[contains(text(),'确定')] | //button[contains(text(),'确认发送')]",
      "descript": "确认群发",
      "timeout": 5000,
      "is_try": true
    },
    {
      "type": "evaluate_edit",
      "value": "return window.location.href;",
      "descript": "获取发布后 URL",
      "timeout": 3000
    }
  ]
}
