{
  "platform": "wxgzh",
  "version": "1.7.0",
  "description": "微信公众号图文发布流程（基于 wxgzh.pyc 反编译的真实确定性步骤 + AI 兜底）",
  "is_placeholder": false,
  "login_check_url": "https://mp.weixin.qq.com/cgi-bin/home",
  "login_check_selector": "div.weui-desktop_name | .account_info",
  "login_check_url_pattern": "^https://mp\\.weixin\\.qq\\.com/cgi-bin/loginpage",
  "logout_keywords": ["登录", "请登录", "sign in"],
  "steps": [
    {
      "type": "navigate",
      "value": "https://mp.weixin.qq.com/cgi-bin/home",
      "descript": "导航到微信公众号主页",
      "timeout": 30000
    },
    {
      "type": "click",
      "selector": "//a[text()=\"登录\"]",
      "descript": "点击登录按钮",
      "is_try": true,
      "timeout": 5000
    },
    {
      "type": "wait_for_selector",
      "selector": "div.weui-desktop_name",
      "descript": "等待登录完成",
      "timeout": 30000
    },
    {
      "type": "click",
      "selector": "//li[@class=\"weui-desktop-menu__item weui-desktop-menu_create menu-fold\"]",
      "descript": "进入内容管理",
      "timeout": 5000
    },
    {
      "type": "click",
      "selector": "//span[text()=\"草稿箱\"]",
      "descript": "点击草稿箱",
      "timeout": 5000
    },
    {
      "type": "click",
      "selector": "//button[text()=\"新的创作\"] | //i[@class=\"weui-desktop-card__icon-add\"]",
      "descript": "点击新的创作",
      "timeout": 5000
    },
    {
      "type": "click",
      "selector": "//i[@class=\"icon-svg-editor-appmsg\"] | //span[text()=\"文章\" and @class=\"weui-desktop-dropdown__list-ele__text\"]",
      "descript": "选择文章类型",
      "timeout": 5000
    },
    {
      "type": "fill",
      "selector": "//div[@data-placeholder=\"请在这里输入标题\"]",
      "value": "{title}",
      "descript": "填写文章标题",
      "ai_fallback": true,
      "ai_intent": "找到微信公众号标题输入框并填写",
      "timeout": 5000
    },
    {
      "type": "fill",
      "selector": "input[placeholder=\"请输入作者\"]",
      "value": "聚量引力",
      "descript": "输入作者",
      "is_try": true,
      "timeout": 5000
    },
    {
      "type": "press",
      "selector": "//div[text()=\"从这里开始写正文\"]",
      "value": "{content}",
      "descript": "输入正文",
      "ai_fallback": true,
      "ai_intent": "找到微信公众号正文编辑区并填写内容",
      "timeout": 5000
    },
    {
      "type": "hover",
      "selector": "//div[@class=\"select-cover__btn js_cover_btn_area select-cover__mask\"]",
      "descript": "鼠标移入封面选择器",
      "timeout": 5000
    },
    {
      "type": "click",
      "selector": "//div[@class=\"pop-opr__group pop-opr__group-select-cover js_cover_null_pop js_cover_opr\"]//a[text()=\"从正文选择\"]",
      "descript": "从正文选择封面",
      "timeout": 5000
    },
    {
      "type": "click",
      "selector": "li.appmsg_content_img_item",
      "descript": "选择封面图片",
      "is_try": true,
      "timeout": 5000
    },
    {
      "type": "click",
      "selector": "//button[text()=\"下一步\"]",
      "descript": "确认图片",
      "is_try": true,
      "timeout": 5000
    },
    {
      "type": "click",
      "selector": "//button[text()=\"确认\"]",
      "descript": "确认",
      "is_try": true,
      "timeout": 5000
    },
    {
      "type": "branch",
      "condition": "data_item.is_yuanchuang === true",
      "branch_steps": [
        {
          "type": "click",
          "selector": "//div[text()=\"声明原创成功后将获得平台著作权保护，并有可能得到推荐\"]",
          "descript": "点击声明原创",
          "is_try": true,
          "timeout": 5000
        },
        {
          "type": "click",
          "selector": "i.weui-desktop-icon-checkbox",
          "descript": "勾选原创复选框",
          "is_try": true,
          "timeout": 5000
        },
        {
          "type": "click",
          "selector": "//div[@class=\"weui-desktop-dialog\"]//button[text()=\"确定\"]",
          "descript": "确认原创声明",
          "is_try": true,
          "timeout": 5000
        }
      ],
      "descript": "声明原创分支"
    },
    {
      "type": "click",
      "selector": "//span[text()=\"发表\"] | //button[text()=\"无需声明并发表\"]",
      "descript": "点击发表",
      "ai_fallback": true,
      "ai_intent": "找到微信公众号发表按钮并点击",
      "timeout": 5000
    },
    {
      "type": "timing",
      "ms": 2000,
      "descript": "等待发表完成"
    },
    {
      "type": "evaluate_edit",
      "value": "return window.location.href;",
      "descript": "获取发布后 URL",
      "timeout": 3000
    }
  ]
}
