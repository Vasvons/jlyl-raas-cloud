{
  "platform": "bili",
  "version": "1.0.0",
  "description": "B站专栏发布流程：member.bilibili.com/article-text/articleCreate（v1.5.6 模板，需基于实测调整选择器）",
  "is_placeholder": true,
  "login_check_url": "https://member.bilibili.com/article-text/home",
  "login_check_selector": "//div[contains(@class,'user-info')] | //div[contains(@class,'header-avatar')]",
  "logout_keywords": ["登录", "请登录", "sign in"],
  "steps": [
    {
      "type": "navigate",
      "value": "https://member.bilibili.com/article-text/articleCreate",
      "descript": "导航到B站专栏发布页",
      "timeout": 30000
    },
    {
      "type": "wait_for_selector",
      "selector": "//input[@placeholder='请输入标题'] | //input[contains(@class,'title-input')] | //input[@id='title']",
      "descript": "等待标题输入框",
      "timeout": 15000
    },
    {
      "type": "fill",
      "selector": "//input[@placeholder='请输入标题'] | //input[contains(@class,'title-input')] | //input[@id='title']",
      "value": "{title}",
      "descript": "填写标题",
      "timeout": 5000
    },
    {
      "type": "click",
      "selector": "//div[@contenteditable='true'] | //div[contains(@class,'ql-editor')] | //div[contains(@class,'editor-content')]",
      "descript": "点击正文编辑区（Quill 编辑器）",
      "timeout": 5000
    },
    {
      "type": "content",
      "selector": "//div[@contenteditable='true'] | //div[contains(@class,'ql-editor')] | //div[contains(@class,'editor-content')]",
      "value": "{content}",
      "descript": "粘贴正文",
      "timeout": 10000
    },
    {
      "type": "click",
      "selector": "//button[contains(text(),'发布')] | //button[contains(@class,'submit')]",
      "descript": "点击发布按钮",
      "timeout": 8000
    },
    {
      "type": "wait_for_url",
      "value": "www.bilibili.com/read/",
      "descript": "等待跳转到专栏阅读页",
      "timeout": 30000
    },
    {
      "type": "evaluate_edit",
      "value": "return window.location.href;",
      "descript": "获取发布后 URL",
      "timeout": 3000
    }
  ]
}
