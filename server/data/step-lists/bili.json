{
  "platform": "bili",
  "version": "1.7.1",
  "description": "B站专栏图文发布流程（基于 bili.pyc 反编译的真实确定性步骤 + AI 兜底）",
  "is_placeholder": false,
  "login_check_url": "https://member.bilibili.com/platform/upload/text/new-edit",
  "login_check_selector": ".header-avatar | .user-info",
  "login_check_url_pattern": "^https://passport\\.bilibili\\.com/login",
  "logout_keywords": ["请登录", "sign in"],
  "steps": [
    {
      "type": "navigate",
      "value": "https://member.bilibili.com/platform/upload/text/new-edit",
      "descript": "导航到B站专栏编辑页",
      "timeout": 30000
    },
    {
      "type": "iframe_selector",
      "iframe": "div.iframe-comp-container iframe",
      "descript": "进入专栏编辑 iframe",
      "is_list": [
        {
          "type": "fill",
          "selector": "textarea",
          "value": "{title}",
          "descript": "填写标题",
          "ai_fallback": true,
          "ai_intent": "找到B站标题输入框并填写",
          "timeout": 5000
        },
        {
          "type": "click",
          "selector": "//div[@contenteditable=\"true\"]",
          "descript": "点击正文区",
          "timeout": 5000
        },
        {
          "type": "press",
          "selector": "//div[@contenteditable=\"true\"]",
          "value": "{content}",
          "descript": "输入正文",
          "ai_fallback": true,
          "ai_intent": "找到B站正文编辑区并填写内容",
          "timeout": 5000
        }
      ]
    },
    {
      "type": "click",
      "selector": "//button[text()=\"提交文章\"] | //button[text()=\"发布\"]",
      "descript": "提交发布",
      "ai_fallback": true,
      "ai_intent": "找到B站发布按钮并点击",
      "timeout": 5000
    },
    {
      "type": "wait_for_selector",
      "selector": "//div[contains(text(),\"发布成功\")] | //div[contains(@class,\"success\")]",
      "descript": "等待发布成功",
      "timeout": 30000,
      "is_try": true
    },
    {
      "type": "evaluate_edit",
      "value": "return window.location.href;",
      "descript": "获取发布后 URL",
      "timeout": 3000
    }
  ]
}
