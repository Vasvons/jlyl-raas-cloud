{
  "platform": "xhs",
  "version": "1.7.2",
  "description": "小红书图文发布流程（基于 red.pyc 反编译的真实确定性步骤 + AI 兜底）",
  "is_placeholder": false,
  "login_check_url": "https://creator.xiaohongshu.com/publish/publish?from=menu",
  "login_check_selector": "input[placeholder='填写标题会有更多赞哦'] | input[type='file'] | div[contenteditable='true']",
  "login_check_url_pattern": "^https://creator\\.xiaohongshu\\.com/login\\?source=.*",
  "logout_keywords": ["请登录", "sign in"],
  "steps": [
    {
      "type": "navigate",
      "value": "https://creator.xiaohongshu.com/publish/publish?from=menu&target=image",
      "descript": "导航到小红书图文发布页",
      "timeout": 30000
    },
    {
      "type": "wait_for_url",
      "value": "publish/publish",
      "descript": "等待进入发布页",
      "timeout": 15000
    },
    {
      "type": "input_files",
      "selector": "//input[@type='file']",
      "files": ["{cover_image_url}"],
      "descript": "上传图片",
      "timeout": 10000
    },
    {
      "type": "keyboard_type",
      "selector": "//input[@placeholder='填写标题会有更多赞哦']",
      "value": "{title}",
      "descript": "逐字符输入标题",
      "humanize": true,
      "ai_fallback": true,
      "ai_intent": "找到小红书标题输入框并逐字符输入",
      "timeout": 5000
    },
    {
      "type": "tags",
      "selector": "//input[@placeholder='填写标题会有更多赞哦'] | //div[contains(@class,'tag-input')]//input",
      "value": "{tags}",
      "descript": "添加话题",
      "is_try": true,
      "timeout": 5000
    },
    {
      "type": "branch",
      "condition": "data_item.poi_name",
      "branch_steps": [
        {
          "type": "fill",
          "selector": "//div[text()=\"添加地点\"]/preceding-sibling::div[1]/input",
          "value": "data_item.poi_name",
          "descript": "填写地点",
          "is_try": true,
          "timeout": 5000
        }
      ],
      "descript": "地点填写分支"
    },
    {
      "type": "timing",
      "ms": 1500,
      "descript": "等待表单稳定"
    },
    {
      "type": "get_by_xy",
      "selector": "shadow:.publish-btn",
      "descript": "点击发布按钮（Shadow DOM）",
      "ai_fallback": true,
      "ai_intent": "找到小红书发布按钮并点击",
      "timeout": 5000
    },
    {
      "type": "wait_for_url",
      "value": "publish/success",
      "descript": "等待发布成功",
      "timeout": 30000,
      "is_try": true
    },
    {
      "type": "evaluate_edit",
      "value": "return window.location.href;",
      "descript": "获取发布后 URL",
      "timeout": 3000
    }
  ]
}
