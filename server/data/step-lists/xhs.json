{
  "platform": "xhs",
  "version": "1.0.0",
  "description": "小红书图文发布流程：creator.xiaohongshu.com/publish/publish（v1.5.6 模板，需基于实测调整选择器）",
  "is_placeholder": true,
  "login_check_url": "https://creator.xiaohongshu.com/publish/publish",
  "login_check_selector": "//div[contains(@class,'user-info')] | //div[contains(@class,'creator')]",
  "logout_keywords": ["登录", "请登录", "sign in"],
  "steps": [
    {
      "type": "navigate",
      "value": "https://creator.xiaohongshu.com/publish/publish",
      "descript": "导航到小红书创作者发布页",
      "timeout": 30000
    },
    {
      "type": "wait_for_selector",
      "selector": "//div[contains(@class,'upload')] | //div[contains(@class,'publish')] | //input[@type='file']",
      "descript": "等待发布页加载（小红书需先上传封面图）",
      "timeout": 15000
    },
    {
      "type": "fill",
      "selector": "//input[@placeholder='填写标题'] | //input[contains(@class,'title')] | //textarea[contains(@class,'title')]",
      "value": "{title}",
      "descript": "填写标题",
      "timeout": 5000,
      "is_try": true
    },
    {
      "type": "click",
      "selector": "//div[@contenteditable='true'] | //div[contains(@class,'desc-input')] | //div[contains(@class,'content-input')]",
      "descript": "点击正文编辑区",
      "timeout": 5000,
      "is_try": true
    },
    {
      "type": "content",
      "selector": "//div[@contenteditable='true'] | //div[contains(@class,'desc-input')] | //div[contains(@class,'content-input')]",
      "value": "{content}",
      "descript": "粘贴正文",
      "timeout": 10000,
      "is_try": true
    },
    {
      "type": "click",
      "selector": "//button[contains(text(),'发布')] | //button[contains(@class,'publish-btn')] | //span[contains(text(),'发布')]/..",
      "descript": "点击发布按钮",
      "timeout": 8000
    },
    {
      "type": "wait_for_url",
      "value": "creator.xiaohongshu.com/publish/success",
      "descript": "等待跳转到发布成功页",
      "timeout": 30000
    },
    {
      "type": "evaluate_edit",
      "value": "return window.location.href;",
      "descript": "获取发布后 URL",
      "timeout": 3000
    }
  ]
}
