{
  "platform": "xhs",
  "version": "1.1.0",
  "description": "小红书图文发布流程：https://creator.xiaohongshu.com/publish/publish（v1.5.6 混合模式，AI 视觉识别元素）",
  "is_placeholder": true,
  "login_check_url": "https://creator.xiaohongshu.com/publish/publish",
  "login_check_selector": "//div[contains(@class,'user-info')] | //div[contains(@class,'avatar')]",
  "logout_keywords": ["登录", "请登录", "sign in"],
  "steps": [
    {
      "type": "navigate",
      "value": "https://creator.xiaohongshu.com/publish/publish",
      "descript": "导航到小红书图文编辑页",
      "timeout": 30000
    },
    {
      "type": "timing",
      "ms": 3000,
      "descript": "等待页面加载"
    },
    {
      "type": "ai_action",
      "intent": "找到文章标题输入框（通常是页面上方的输入框，placeholder 可能含'标题'或'Title'）",
      "ai_action": "fill",
      "value": "{title}",
      "max_retries": 2,
      "descript": "AI识别标题框并填写标题"
    },
    {
      "type": "ai_action",
      "intent": "找到正文编辑区域（通常是页面中间的可编辑区域，可能含'开始写作'或空白富文本区）并点击",
      "ai_action": "click",
      "max_retries": 2,
      "descript": "AI识别正文区并点击"
    },
    {
      "type": "timing",
      "ms": 1000,
      "descript": "等待正文区聚焦"
    },
    {
      "type": "ai_action",
      "intent": "在当前聚焦的正文编辑区域填入文章内容",
      "ai_action": "fill",
      "value": "{content}",
      "max_retries": 2,
      "descript": "AI识别正文区并填写内容"
    },
    {
      "type": "ai_action",
      "intent": "找到页面上的'发布'或'发表'按钮（通常在右上角或底部，红色或蓝色主色调）并点击",
      "ai_action": "click",
      "max_retries": 2,
      "descript": "AI识别发布按钮并点击"
    },
    {
      "type": "timing",
      "ms": 2000,
      "descript": "等待可能的确认弹窗"
    },
    {
      "type": "ai_action",
      "intent": "如果出现确认发布弹窗，找到'确认发布'或'确定'或'确认'按钮并点击",
      "ai_action": "click",
      "max_retries": 1,
      "is_try": true,
      "descript": "AI识别确认弹窗按钮（可选）"
    },
    {
      "type": "timing",
      "ms": 3000,
      "descript": "等待发布完成跳转"
    },
    {
      "type": "evaluate_edit",
      "value": "return window.location.href;",
      "descript": "获取发布后 URL",
      "timeout": 3000
    }
  ]
}
