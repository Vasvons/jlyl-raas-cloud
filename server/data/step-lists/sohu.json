{
  "platform": "sohu",
  "version": "1.7.0",
  "description": "搜狐号图文发布流程（基于 sohu.pyc 反编译的真实确定性步骤 + AI 兜底）",
  "is_placeholder": false,
  "login_check_url": "https://mp.sohu.com/mpfe/v4/contentManagement/first/page",
  "login_check_selector": ".user-info | .user-avatar",
  "login_check_url_pattern": "^https://mp\\.sohu\\.com/mpfe/v4/login",
  "logout_keywords": ["登录", "请登录", "sign in"],
  "steps": [
    {
      "type": "navigate",
      "value": "https://mp.sohu.com/mpfe/v4/contentManagement/first/page",
      "descript": "导航到搜狐号主页",
      "timeout": 30000
    },
    {
      "type": "hover",
      "selector": "//div[contains(@class,\"user-info\")] | //div[contains(@class,\"account-menu\")]",
      "descript": "鼠标移入账号菜单",
      "timeout": 5000
    },
    {
      "type": "click",
      "selector": "//a[text()=\"进入\"] | //a[contains(text(),\"内容管理\")]",
      "descript": "进入内容管理",
      "timeout": 5000
    },
    {
      "type": "click",
      "selector": "//button[text()=\"发布内容\"] | //span[text()=\"发布内容\"]",
      "descript": "点击发布内容",
      "is_try": true,
      "timeout": 5000
    },
    {
      "type": "wait_for_url",
      "value": "contentManagement",
      "descript": "等待进入发布页",
      "timeout": 15000,
      "is_try": true
    },
    {
      "type": "fill",
      "selector": "//input[@placeholder=\"请输入标题\"] | //textarea[@placeholder=\"请输入标题\"]",
      "value": "{title}",
      "descript": "填写文章标题",
      "ai_fallback": true,
      "ai_intent": "找到搜狐标题输入框并填写",
      "timeout": 5000
    },
    {
      "type": "press",
      "selector": "//div[@contenteditable=\"true\"]",
      "value": "{content}",
      "descript": "输入正文",
      "ai_fallback": true,
      "ai_intent": "找到搜狐正文编辑区并填写内容",
      "timeout": 5000
    },
    {
      "type": "click",
      "selector": "//button[text()=\"生成摘要\"] | //span[text()=\"生成摘要\"]",
      "descript": "生成摘要",
      "is_try": true,
      "timeout": 5000
    },
    {
      "type": "input_files",
      "selector": "//input[@type=\"file\"]",
      "files": ["{cover_image_url}"],
      "descript": "上传图片",
      "is_try": true,
      "timeout": 10000
    },
    {
      "type": "branch",
      "condition": "data_item.ai_status === true",
      "branch_steps": [],
      "descript": "AI声明分支（留空，未来扩展）"
    },
    {
      "type": "timing",
      "ms": 1000,
      "descript": "等待表单稳定"
    },
    {
      "type": "click",
      "selector": "//button[text()=\"发布\"] | //span[text()=\"发布\"]",
      "descript": "点击发布",
      "ai_fallback": true,
      "ai_intent": "找到搜狐发布按钮并点击",
      "timeout": 5000
    },
    {
      "type": "wait_for_url",
      "value": "contentManage",
      "descript": "等待发布成功",
      "timeout": 30000,
      "is_try": true
    },
    {
      "type": "evaluate_edit",
      "value": "return window.location.href;",
      "descript": "获取发布后 URL",
      "timeout": 3000
    }
  ]
}
