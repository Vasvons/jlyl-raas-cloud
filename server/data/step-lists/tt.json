{
  "platform": "tt",
  "version": "1.0.0",
  "description": "今日头条号图文发布流程：mp.toutiao.com/profile_v4/graphic/publish（v1.5.6 模板，需基于实测调整选择器）",
  "is_placeholder": true,
  "login_check_url": "https://mp.toutiao.com/profile_v4/index",
  "login_check_selector": "//div[contains(@class,'user-info')] | //div[contains(@class,'avatar')]",
  "logout_keywords": ["登录", "请登录", "sign in"],
  "steps": [
    {
      "type": "navigate",
      "value": "https://mp.toutiao.com/profile_v4/graphic/publish",
      "descript": "导航到头条号图文发布页",
      "timeout": 30000
    },
    {
      "type": "wait_for_selector",
      "selector": "//textarea[@placeholder='请输入文章标题'] | //input[@placeholder='请输入文章标题'] | //div[contains(@class,'title-input')]",
      "descript": "等待标题输入框",
      "timeout": 15000
    },
    {
      "type": "fill",
      "selector": "//textarea[@placeholder='请输入文章标题'] | //input[@placeholder='请输入文章标题'] | //div[contains(@class,'title-input')]//textarea",
      "value": "{title}",
      "descript": "填写标题",
      "timeout": 5000
    },
    {
      "type": "click",
      "selector": "//div[@contenteditable='true'] | //div[contains(@class,'ProEditor-content')] | //div[contains(@class,'ql-editor')]",
      "descript": "点击正文编辑区",
      "timeout": 5000
    },
    {
      "type": "content",
      "selector": "//div[@contenteditable='true'] | //div[contains(@class,'ProEditor-content')] | //div[contains(@class,'ql-editor')]",
      "value": "{content}",
      "descript": "粘贴正文",
      "timeout": 10000
    },
    {
      "type": "click",
      "selector": "//button[contains(text(),'发布')] | //button[contains(@class,'publish-btn')]",
      "descript": "点击发布按钮",
      "timeout": 8000
    },
    {
      "type": "wait_for_url",
      "value": "toutiao.com/article/",
      "descript": "等待跳转到文章页",
      "timeout": 30000
    },
    {
      "type": "evaluate_edit",
      "value": "return window.location.href;",
      "descript": "获取发布后 URL",
      "timeout": 3000
    }
  ]
}
