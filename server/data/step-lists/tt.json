{
  "platform": "tt",
  "version": "1.7.4",
  "description": "今日头条图文发布流程（基于 toutiao.pyc 反编译的真实确定性步骤 + AI 兜底）",
  "is_placeholder": false,
  "login_check_url": "https://mp.toutiao.com/profile_v4/graphic/publish",
  "login_check_selector": "textarea[placeholder*='标题'] | div[contenteditable='true']",
  "login_check_url_pattern": "^https://mp\\.toutiao\\.com/auth/page/login\\?redirect_url=.*",
  "logout_keywords": ["请登录", "sign in"],
  "steps": [
    {
      "type": "navigate",
      "value": "https://mp.toutiao.com/profile_v4/graphic/publish",
      "descript": "导航到今日头条图文发布页",
      "timeout": 30000
    },
    {
      "type": "click",
      "selector": "svg.close-btn",
      "descript": "关闭弹窗",
      "is_try": true,
      "timeout": 5000
    },
    {
      "type": "fill",
      "selector": "textarea[placeholder='请输入文章标题（2～30个字）']",
      "value": "{title}",
      "descript": "填写文章标题",
      "ai_fallback": true,
      "ai_intent": "找到头条标题输入框并填写",
      "timeout": 5000
    },
    {
      "type": "press",
      "selector": "//div[@contenteditable='true']",
      "value": "{content}",
      "descript": "输入正文",
      "ai_fallback": true,
      "ai_intent": "找到头条正文编辑区并填写内容",
      "timeout": 5000
    },
    {
      "type": "click",
      "selector": "div.article-cover-add",
      "descript": "上传图片",
      "is_try": true,
      "timeout": 5000
    },
    {
      "type": "click",
      "selector": "//span[text()=\"确定\"]",
      "descript": "确认图片",
      "is_try": true,
      "timeout": 5000
    },
    {
      "type": "click",
      "selector": "//label[@class=\"byte-checkbox checkbot-item checkbox-with-tip byte-checkbox-checked\"]",
      "descript": "去掉首发声明",
      "is_try": true,
      "timeout": 5000
    },
    {
      "type": "branch",
      "condition": "data_item.ai_status === true",
      "branch_steps": [
        {
          "type": "click",
          "selector": "//span[text()=\"引用AI\"]",
          "descript": "勾选引用AI声明",
          "is_try": true,
          "timeout": 5000
        }
      ],
      "descript": "AI引用声明分支"
    },
    {
      "type": "timing",
      "ms": 1000,
      "descript": "等待选项生效"
    },
    {
      "type": "press",
      "value": "Escape",
      "descript": "按 ESC 关闭图片预览抽屉（如有）",
      "is_try": true,
      "timeout": 2000
    },
    {
      "type": "timing",
      "ms": 800,
      "descript": "等待抽屉消失"
    },
    {
      "type": "click",
      "selector": "//span[text()=\"预览并发布\"] | //span[text()=\"预览并定时发布\"] | //button[contains(@class,\"byte-btn-primary\")]//span[text()=\"发布\"]",
      "descript": "预览并发布",
      "ai_fallback": true,
      "ai_intent": "找到头条发布按钮并点击",
      "timeout": 5000,
      "force": true
    },
    {
      "type": "timing",
      "ms": 2000,
      "descript": "等待发布请求处理"
    },
    {
      "type": "wait_for_url",
      "value": "profile_v4/graphic/articles",
      "descript": "等待发布成功",
      "timeout": 30000
    },
    {
      "type": "evaluate_edit",
      "value": "return window.location.href;",
      "descript": "获取发布后 URL",
      "timeout": 3000
    }
  ]
}
