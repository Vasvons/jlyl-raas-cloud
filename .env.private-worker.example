# ====================================================================
# 私有部署 Worker 环境变量配置（v2.5.36）
# ====================================================================
# 复制本文件为 .env，然后修改以下变量：
#   cp .env.private-worker.example .env
# ====================================================================

# 【必填】私有部署授权码（购买套餐后从客户端「订阅管理 → 私有部署」获取）
LICENSE_KEY=JLYL-PD-XXXXXXXXXXXXXXXX

# 【必填】服务器名称（用于在客户端显示，方便识别）
SERVER_NAME=我的私有服务器

# 【必填】云端 API 地址（公网地址）
#   生产环境：https://report.jlyl.net.cn
#   测试环境：http://xxx.xxx.xxx.xxx:3002
CLOUD_API_URL=https://report.jlyl.net.cn

# 【选填】巡检 Worker 最大并发数（默认 4，建议 2 核 4G 服务器设为 4，4 核 8G 可设为 8）
#   注意：并发越高，浏览器内存占用越大，2G 内存限制下建议不超过 4
COLLECT_MAX_CONCURRENCY=4

# 【选填】发布 Worker 最大并发数（默认 2，发布任务较重，建议不超过 2）
PUBLISH_MAX_CONCURRENT=2

# 【选填】发布 Worker 认证密钥（与云端保持一致，一般无需修改）
WORKER_SECRET=jlyl-cloud-worker-secret-2024
